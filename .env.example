# Postgres connection string.
# On Railway this is provided automatically when you add a Postgres database —
# you do NOT need to set it by hand there.
# For local development, point it at a local Postgres instance:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cocktailboard

# Secret used to sign login cookies. Use any long random string.
# On Railway, set this once in the service Variables tab.
SESSION_SECRET=change-me-to-a-long-random-string
